# PageGate Watcher 环境变量
# 复制这份文件为 .env，然后填入实际值
# PAGEGATE_API_TOKEN 这里保存的是 PageGate API token
# 托管服务器或开启注册的自部署服务器都可以通过 quick-register 获取
# PAGEGATE_NAME / PAGEGATE_USERNAME / PAGEGATE_HOME_URL / PAGEGATE_DASHBOARD_URL 是便于人工识别的元数据
# PAGEGATE_HOME_URL 是你的个人 PageGate 首页，只聚合公开页面
# PAGEGATE_DASHBOARD_URL 用来查看全部页面和授权状态

PAGEGATE_URL=http://115.190.148.77:8888
PAGEGATE_API_TOKEN=replace-with-your-pagegate-token
PAGEGATE_NAME='My PageGate'
PAGEGATE_USERNAME=my-pagegate
PAGEGATE_HOME_URL=http://115.190.148.77:8888/my-pagegate
PAGEGATE_DASHBOARD_URL='http://115.190.148.77:8888/dashboard?token=replace-with-your-pagegate-token'
OPENCLAW_NOTIFY_CHANNEL=openclaw-weixin
OPENCLAW_NOTIFY_TARGET=your-notify-target-id
OPENCLAW_NOTIFY_ACCOUNT=your-account-id
PAGEGATE_WATCH_LOG_FILE=~/.openclaw/workspace/memory/pagegate-watch.log
PAGEGATE_WATCH_STATE_FILE=~/.openclaw/workspace/memory/pagegate-watch-state.json
PAGEGATE_WATCH_HEALTH_FILE=~/.openclaw/workspace/memory/pagegate-watch-health.json
PAGEGATE_WATCH_PENDING_SYNC_MS=60000
