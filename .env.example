# HTMLHub Watcher 环境变量
# 复制这份文件为 .env，然后填入实际值

HTMLHUB_URL=http://xuanzhang.net:8888
HTMLHUB_ADMIN_TOKEN=replace-with-your-admin-token
OPENCLAW_NOTIFY_CHANNEL=openclaw-weixin
OPENCLAW_NOTIFY_TARGET=your-notify-target-id
OPENCLAW_NOTIFY_ACCOUNT=your-account-id
HTMLHUB_WATCH_LOG_FILE=~/.openclaw/workspace/memory/htmlhub-watch.log
HTMLHUB_WATCH_STATE_FILE=/tmp/htmlhub-watch-state.json
